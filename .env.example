# chat — environment configuration
#
# Two profiles ship in the repo:
#   - .env.example         (this file)        — local CSS, persona names + emails
#   - .env.live.example    (live pod profile) — pods.mindpods.org
#
# Copy one to `.env.local` and fill in the secrets. `.env.local` is gitignored.

# ---- OIDC + chat target ----
# The shared Mind CSS both personas authenticate against (`docker compose up`
# at the workspace root — see ../SOLID-SERVER.md). v0 scope: same issuer for
# both. Cross-server federation (a 2nd CSS for bob) is deferred to v1.
NEXT_PUBLIC_SOLID_ISSUER=http://localhost:3011/

# The room container URL (no trailing slash). Hosted on persona A's pod, under
# chat's own /chat/ namespace so it never collides with sibling apps.
NEXT_PUBLIC_ROOM_URL=http://localhost:3011/alice/chat/general

# ---- Persona A (room owner) ----
# NEXT_PUBLIC_* values appear in the sign-in UI; the others are used by
# server-side scripts (seed, smoke). Emails match the shared seed.
NEXT_PUBLIC_PERSONA_A_NAME=Alice
PERSONA_A_EMAIL=alice@mind.local
PERSONA_A_PASSWORD=dev-only-do-not-use-in-prod
PERSONA_A_WEBID="http://localhost:3011/alice/profile/card#me"

# ---- Persona B (room member) ----
NEXT_PUBLIC_PERSONA_B_NAME=Bob
PERSONA_B_EMAIL=bob@mind.local
PERSONA_B_PASSWORD=dev-only-do-not-use-in-prod
PERSONA_B_WEBID="http://localhost:3011/bob/profile/card#me"
