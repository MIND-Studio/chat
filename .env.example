# mind-chat-v0 — environment configuration
#
# Two profiles ship in the repo:
#   - .env.example         (this file)        — local CSS, persona names + emails
#   - .env.live.example    (live pod profile) — pod.mindpods.org
#
# Copy one to `.env.local` and fill in the secrets. `.env.local` is gitignored.

# ---- OIDC + chat target ----
# The CSS instance both personas authenticate against. v0 scope: same issuer
# for both. Cross-server federation deferred to v1.
NEXT_PUBLIC_SOLID_ISSUER=http://localhost:3031/

# The room container URL (no trailing slash). Hosted on persona A's pod.
NEXT_PUBLIC_ROOM_URL=http://localhost:3031/alice/chat/general

# ---- Persona A (room owner) ----
# NEXT_PUBLIC_* values appear in the sign-in UI; the others are used by
# server-side scripts (seed, smoke).
NEXT_PUBLIC_PERSONA_A_NAME=Alice
PERSONA_A_EMAIL=alice@mind-chat.local
PERSONA_A_PASSWORD=dev-only-do-not-use-in-prod
PERSONA_A_WEBID="http://localhost:3031/alice/profile/card#me"

# ---- Persona B (room member) ----
NEXT_PUBLIC_PERSONA_B_NAME=Bob
PERSONA_B_EMAIL=bob@mind-chat.local
PERSONA_B_PASSWORD=dev-only-do-not-use-in-prod
PERSONA_B_WEBID="http://localhost:3031/bob/profile/card#me"
