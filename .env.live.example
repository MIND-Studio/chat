# mind-chat-v0 — live-pod profile
#
# Points the prototype at the production CSS at pod.mindpods.org
# instead of the local Docker CSS. Both personas live on that single CSS;
# the room is hosted on testuser's pod with chat-bob granted ACL read+append.
#
# Copy to `.env.local` and fill in the passwords. Never commit `.env.local`.

NEXT_PUBLIC_SOLID_ISSUER=https://pod.mindpods.org/
NEXT_PUBLIC_ROOM_URL=https://pod.mindpods.org/testuser/chat/general

# Persona A = the existing testuser account.
NEXT_PUBLIC_PERSONA_A_NAME=Test User
PERSONA_A_EMAIL=
PERSONA_A_PASSWORD=
PERSONA_A_WEBID="https://pod.mindpods.org/testuser/profile/card#me"

# Persona B = the chat-bob account provisioned by the seed flow.
NEXT_PUBLIC_PERSONA_B_NAME=Chat Bob
PERSONA_B_EMAIL=chat-bob@mind-chat.local
PERSONA_B_PASSWORD=dev-only-mind-chat-bob-2026
PERSONA_B_WEBID="https://pod.mindpods.org/chat-bob/profile/card#me"
