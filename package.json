{
  "name": "chat",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3030",
    "build": "next build",
    "start": "next start --port 3030",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --passWithNoTests",
    "prepare": "husky",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:feedback": "tsx scripts/seed-feedback-inbox.ts",
    "fix:acl": "tsx scripts/fix-room-acl.ts",
    "smoke:pods": "tsx scripts/smoke-pods.ts",
    "smoke:roundtrip": "tsx scripts/smoke-roundtrip.ts",
    "smoke:ui": "tsx scripts/smoke-ui.ts",
    "chat:watch": "tsx scripts/chat-watch.ts",
    "chat:send": "tsx scripts/chat-send.ts",
    "seed:feedback:all": "tsx scripts/seed-feedback-inboxes-all.ts"
  },
  "dependencies": {
    "@inrupt/solid-client": "^3.0.0",
    "@inrupt/solid-client-authn-browser": "^4.0.0",
    "@inrupt/solid-client-authn-node": "^3.1.1",
    "@inrupt/solid-client-notifications": "^4.0.0",
    "@mind-studio/core": "^0.7.0",
    "@mind-studio/ui": "^0.7.0",
    "dotenv": "^17.4.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "vitest": "^4.1.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
